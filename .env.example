# ─────────────────────────────────────────────────────────────
# LINE Trip Intelligence — environment variables
# Copy to .env.local and fill in. NEVER commit real values.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase (server-only — NEVER expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# LINE Messaging API (server-only)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# AI extraction via OpenRouter (server-only)
# Provider adapter is OpenRouter-compatible; swap AI_MODEL to change models.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
AI_MODEL=moonshotai/kimi-k3
# OpenRouter recommends identifying your app:
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=LINE Trip Intelligence

# Background job authentication (server-only)
# Generate with: openssl rand -hex 32
INTERNAL_JOB_SECRET=

# Monitoring (optional)
SENTRY_DSN=
